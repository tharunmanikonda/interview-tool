{
  "name": "@gptdisguise/docs-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --config vite.config.ts && tsx src/server.ts",
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@gptdisguise/live-doc-core": "workspace:*",
    "@gptdisguise/live-doc-ui": "workspace:*",
    "@gptdisguise/protocol": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^6.4.3"
  }
}
